# Dev image: installs ALL dependencies (including devDependencies for TypeScript, etc.)
# Source code is volume-mounted at runtime for hot-reload
FROM node:18-alpine

WORKDIR /app

# Copy package files and install all dependencies (dev + prod)
COPY package*.json ./
RUN npm ci

EXPOSE 3000

# Next.js dev server with hot-reload
CMD ["npm", "run", "dev"]
